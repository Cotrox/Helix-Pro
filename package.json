{
  "name": "helix-pro",
  "private": true,
  "version": "0.0.8",
  "description": "Desktop app for managing Helix Pro shooting competitions.",
  "author": "Helix Pro",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://127.0.0.1:3000 && electron .",
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:all": "npm run dev",
    "start": "npm run build:renderer && electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer",
    "dist": "npm run clean && npm run build:renderer && electron-builder",
    "dist:win": "npm run clean && npm run build:renderer && electron-builder --win portable",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true }); require('fs').rmSync('release', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.29.0",
    "dotenv": "^17.2.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.3",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "sonner": "^2.0.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.helixpro.app",
    "productName": "Helix Pro",
    "publish": [
      {
        "provider": "github",
        "owner": "Cotrox",
        "repo": "Helix-Pro"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "portable",
        "appx"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Helix Pro",
      "license": "build/info.txt",
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "appx": {
      "identityName": "Cotrox.HelixPro",
      "publisher": "CN=9028411D-2DD0-48B6-841C-802A01D6F318",
      "publisherDisplayName": "Cotrox",
      "displayName": "HelixPro"
    }
  }
}